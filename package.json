{
  "name": "x5-vibe-stand",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "X5 Вайб-стенд прототипов",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "concurrently -n api,web \"npm run dev:server\" \"npm run dev:web\"",
    "dev:server": "tsx watch server/index.ts",
    "dev:web": "vite",
    "build": "vite build",
    "start": "cross-env NODE_ENV=production tsx server/index.ts",
    "db:init": "node scripts/init-db.mjs",
    "db:migrate": "node scripts/migrate-db.mjs",
    "proto:sync": "tsx scripts/sync-proto.ts"
  },
  "dependencies": {
    "@ant-design/icons": "^5.6.0",
    "@ant-design/pro-components": "^2.8.0",
    "@emotion/css": "^11.13.0",
    "@hono/node-server": "^1.14.0",
    "@hono/zod-validator": "^0.4.0",
    "@tabler/icons-react": "^3.0.0",
    "@tanstack/react-query": "^5.60.0",
    "antd": "^5.22.0",
    "antd-style": "^3.7.0",
    "better-sqlite3": "^11.0.0",
    "dotenv": "^16.4.0",
    "drizzle-orm": "^0.36.0",
    "drizzle-zod": "^0.5.0",
    "hono": "^4.6.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-router-dom": "^6.28.0",
    "zod": "^3.24.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "concurrently": "^9.0.0",
    "cross-env": "^7.0.3",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vite": "^5.4.0"
  }
}
